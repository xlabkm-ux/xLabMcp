{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BREACH MCP Tool Contract",
  "version": "0.4.0",
  "description": "Formal tool argument contract for the 23-step BREACH pipeline.",
  "steps": {
    "1": ["project_root.set", "editor.state", "asset.create_folder", "asset.exists", "console.read"],
    "2": ["project_root.set", "editor.state", "scene.create", "scene.save", "asset.exists", "console.read"],
    "3": ["project_root.set", "editor.state", "scene.create", "scene.save", "asset.exists", "console.read"],
    "4": ["scene.open", "gameobject.create", "gameobject.modify", "scene.save", "console.read", "screenshot.scene"],
    "5": ["scene.open", "gameobject.create", "component.add", "component.set", "scene.save", "console.read"],
    "6": ["script.create_or_edit", "editor.compile_status", "console.read", "asset.refresh"],
    "7": ["script.create_or_edit", "editor.compile_status", "console.read"],
    "8": ["prefab.create", "prefab.open", "component.add", "prefab.save", "scene.open", "prefab.instantiate", "scene.save"],
    "9": ["script.create_or_edit", "graph.open_or_create", "graph.connect", "editor.compile_status", "console.read"],
    "10": ["script.create_or_edit", "graph.edit", "editor.compile_status", "console.read"],
    "11": ["script.create_or_edit", "component.add", "scene.save", "editor.compile_status", "console.read"],
    "12": ["script.create_or_edit", "tests.run_editmode", "tests.results", "console.read"],
    "13": ["prefab.create", "component.add", "prefab.save", "scene.open", "prefab.instantiate", "scene.save"],
    "14": ["script.create_or_edit", "component.set", "scene.save", "console.read", "screenshot.scene"],
    "15": ["script.create_or_edit", "component.add", "editor.compile_status", "console.read"],
    "16": ["graph.edit", "script.create_or_edit", "scene.save", "console.read"],
    "17": ["prefab.create", "script.create_or_edit", "scene.save", "console.read"],
    "18": ["gameobject.create", "component.add", "script.create_or_edit", "scene.save", "console.read"],
    "19": ["ui.create_or_edit", "localization.key_add", "scene.save", "console.read"],
    "20": ["script.create_or_edit", "scriptableobject.create_or_edit", "editor.compile_status", "console.read"],
    "21": ["script.create_or_edit", "playmode.enter", "playmode.exit", "console.read"],
    "22": ["scene.validate_refs", "prefab.validate", "graph.validate", "tests.run_all", "console.read", "screenshot.scene"],
    "23": ["asset.list_modified", "change.summary", "project.docs_update", "console.read"]
  },
  "tools": {
    "project_root.set": {"type": "object", "required": ["projectRoot"], "properties": {"projectRoot": {"type": "string"}}},
    "scene.open": {"type": "object", "required": ["scenePath"], "properties": {"scenePath": {"type": "string"}}},
    "gameobject.modify": {"type": "object", "required": ["targetPath", "operation"], "properties": {"targetPath": {"type": "string"}, "operation": {"type": "string", "enum": ["rename", "set_active"]}}},
    "component.add": {"type": "object", "required": ["targetPath", "componentType"], "properties": {"targetPath": {"type": "string"}, "componentType": {"type": "string"}}},
    "component.set": {"type": "object", "required": ["targetPath"], "properties": {"targetPath": {"type": "string"}, "active": {"type": "boolean"}}},
    "prefab.create": {"type": "object", "required": ["prefabPath"], "properties": {"sourceObjectPath": {"type": "string"}, "sourcePath": {"type": "string"}, "sourceObjectName": {"type": "string"}, "prefabPath": {"type": "string"}}},
    "prefab.open": {"type": "object", "required": ["prefabPath"], "properties": {"prefabPath": {"type": "string"}}},
    "prefab.instantiate": {"type": "object", "required": ["prefabPath"], "properties": {"prefabPath": {"type": "string"}}},
    "asset.exists": {"type": "object", "required": ["path"], "properties": {"path": {"type": "string"}}},
    "script.create_or_edit": {"type": "object", "properties": {"scriptName": {"type": "string"}, "path": {"type": "string"}, "mode": {"type": "string", "enum": ["create", "append", "replace", "overwrite"]}}},
    "graph.connect": {"type": "object", "properties": {"fromNodeId": {"type": "string"}, "sourceNodeId": {"type": "string"}, "toNodeId": {"type": "string"}, "targetNodeId": {"type": "string"}, "kind": {"type": "string", "enum": ["control", "value"]}}},
    "graph.edit": {"type": "object", "properties": {"operation": {"type": "string", "enum": ["add_node", "remove_node", "set_node"]}, "nodeId": {"type": "string"}, "unitType": {"type": "string"}, "x": {"type": "number"}, "y": {"type": "number"}}},
    "scene.validate_refs": {"type": "object", "properties": {"scenePath": {"type": "string"}}},
    "prefab.validate": {"type": "object", "properties": {"prefabPath": {"type": "string"}}},
    "ui.create_or_edit": {"type": "object", "properties": {"path": {"type": "string"}, "name": {"type": "string"}, "mode": {"type": "string", "enum": ["create", "append", "overwrite"]}}},
    "localization.key_add": {"type": "object", "required": ["key"], "properties": {"key": {"type": "string"}, "value": {"type": "string"}}},
    "build_settings_scenes": {"type": "object", "properties": {"action": {"type": "string", "enum": ["get", "set"]}, "scenes": {"type": "array", "items": {"type": "string"}}}},
    "project.docs_update": {"type": "object", "properties": {"line": {"type": "string"}, "path": {"type": "string"}, "mode": {"type": "string", "enum": ["append", "overwrite"]}}}
  }
}
